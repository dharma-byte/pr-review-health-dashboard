# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://pr_dashboard:pr_dashboard@localhost:5432/pr_dashboard

# Fernet key used to encrypt GitHub tokens at rest.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Regex for origins allowed to call the API. Defaults to any installed Chrome extension.
CORS_ALLOW_ORIGIN_REGEX=^chrome-extension://.*$
